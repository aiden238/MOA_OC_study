# Default LLM runtime
LLM_API_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional providers
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Runtime
DEFAULT_TEMPERATURE=0.7
MAX_TOKENS=1024
MAX_RETRIES=3

# Paths
TRACE_DIR=data/traces
OUTPUT_DIR=data/outputs
BENCHMARK_DIR=data/benchmarks
RAG_DOCS_DIR=data/rag_docs
CHROMA_DIR=data/chroma

# Embeddings
EMBEDDING_API_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
RAG_COLLECTION_NAME=rag_docs

# Optional embedding key override
# EMBEDDING_API_KEY=

# Optional per-agent overrides
# SINGLE_MODEL_PROVIDER=openai
# SINGLE_MODEL=gpt-4o-mini
#
# ROUTER_MODEL_PROVIDER=openai
# ROUTER_MODEL=gpt-4o-mini
#
# DRAFT_ANALYTICAL_MODEL_PROVIDER=gemini
# DRAFT_ANALYTICAL_MODEL=gemini-2.5-flash
#
# DRAFT_CREATIVE_MODEL_PROVIDER=xai
# DRAFT_CREATIVE_MODEL=grok-4
#
# DRAFT_STRUCTURED_MODEL_PROVIDER=openai
# DRAFT_STRUCTURED_MODEL=gpt-4o-mini
#
# CRITIC_MODEL_PROVIDER=openai
# CRITIC_MODEL=gpt-4o-mini
#
# SYNTH_MODEL_PROVIDER=openai
# SYNTH_MODEL=gpt-4o-mini
#
# JUDGE_MODEL_PROVIDER=openai
# JUDGE_MODEL=gpt-4o-mini
#
# REWRITE_MODEL_PROVIDER=openai
# REWRITE_MODEL=gpt-4o-mini
